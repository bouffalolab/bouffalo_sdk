#!/usr/bin/expect

# 设置超时
set timeout 10

# 检查命令行参数
if {$argc != 1} {
    puts "用法: $argv0 <ota文件>"
    puts "错误: 必须指定OTA文件路径"
    exit 1
}

# 定义OTA数据块大小
set ota_filename [lindex $argv 0]
set CHUNK_SIZE 512

# 检查文件是否存在
if {![file exists $ota_filename]} {
    puts "错误: OTA文件不存在: $ota_filename"
    exit 1
}

# 检查文件是否可读
if {![file readable $ota_filename]} {
    puts "错误: OTA文件不可读: $ota_filename"
    exit 1
}

puts "使用OTA文件: $ota_filename"

# 设置串口为原始模式，避免字符编码转换
exec stty -F /dev/ttyHD0 raw -echo -icrnl -ixon -ixoff

# main
spawn -open [open /dev/ttyHD0 "r+"]
fconfigure $spawn_id -translation binary -buffering none

# save spawn_id
set serial_id $spawn_id

# 随时关闭
trap {
    puts "\n检测到 Ctrl+C，正在关闭串口..."
    close -i $serial_id
    exit 0
} SIGINT

# 配置OTA前的准备（非必须）
#send -i $serial_id "AT+CWEVT=0\r\n"
#expect {
#    -i $serial_id "\r\nOK\r\n" {
#    }
#    -i $serial_id timeout {
#        puts "CWEVT, 未收到预期响应"
#        close -i $serial_id
#        exit 0
#    }
#}

send -i $serial_id "AT\r\n"
expect -i $serial_id "OK"

# 配置开始进行START
send -i $serial_id "AT+OTASTART?\r\n"
expect -i $serial_id "OK"

send -i $serial_id "AT+OTASTART=1\r\n"
expect {
    -i $serial_id "\r\nOK\r\n" {
    }
    -i $serial_id timeout {
        puts "OTASTART, 未收到预期响应"
        close -i $serial_id
        exit 0
    }
}

# 开始发送OTA数据文件
set file_handle [open $ota_filename "r"]
fconfigure $file_handle -translation binary

# 获取文件大小
seek $file_handle 0 end
set file_size [tell $file_handle]
seek $file_handle 0 start

puts "开始OTA升级，文件大小: $file_size 字节"

set bytes_sent 0
set chunk_count 0

# 循环读取并发送数据块
while {$bytes_sent < $file_size} {
    # 计算当前数据块大小
    set remaining_bytes [expr {$file_size - $bytes_sent}]
    set current_chunk_size [expr {$remaining_bytes > $CHUNK_SIZE ? $CHUNK_SIZE : $remaining_bytes}]

    puts "发送数据块 $chunk_count: 大小 $current_chunk_size 字节，总进度: $bytes_sent/$file_size"

    # 发送AT+OTASEND命令
    send -i $serial_id "AT+OTASEND=$current_chunk_size\r\n"
    expect {
        -i $serial_id "\r\nOK\r\n" {
            puts "OTASEND命令响应正确"
        }
        -i $serial_id timeout {
            puts "OTASEND命令，未收到预期响应"
            close $file_handle
            close -i $serial_id
            exit 0
        }
    }

    # 读取raw数据
    set data [read $file_handle $current_chunk_size]

    # 重新构造二进制数据，确保发送原始字节
    set byte_list [list]
    for {set i 0} {$i < [string length $data]} {incr i} {
        set byte [string index $data $i]
        binary scan $byte c value
        if {$value < 0} {
            set value [expr {$value + 256}]
        }
        lappend byte_list $value
    }
    set raw_data [binary format c* $byte_list]

    puts "发送 $current_chunk_size 字节原始数据"

    # 直接写入串口，不使用send命令
    puts -nonewline $serial_id $raw_data
    flush $serial_id

    # 等待数据发送确认
    expect {
        -i $serial_id "\r\nSEND OK\r\n" {
            puts "数据块 $chunk_count 发送成功"
        }
        -i $serial_id timeout {
            puts "数据块 $chunk_count，未收到预期响应"
            close $file_handle
            close -i $serial_id
            exit 0
        }
    }

    set bytes_sent [expr {$bytes_sent + $current_chunk_size}]
    set chunk_count [expr {$chunk_count + 1}]
}

close $file_handle
puts "OTA数据发送完成，共发送 $bytes_sent 字节，分 $chunk_count 个数据块"

# OTA完成，并重启
send -i $serial_id "AT+OTAFIN\r\n"
expect {
    -i $serial_id "\r\nOK\r\n" {
    }
    -i $serial_id timeout {
        puts "FIN, 未收到预期响应"
        close -i $serial_id
        exit 0
    }
}
# 关闭串口
close -i $serial_id

