#CONFIG_WL80211   =y
-include $(BL_SDK_BASE)/examples/wifi/defconfig
-include $(BL_SDK_BASE)/examples/wifi/at_defconfig

CONFIG_COREDUMP=n

# easyflash
CONFIG_LITTLEFS              =y
CONFIG_LITTLEFS_KV_EASYFLASH =y
CONFIG_BFLB_MTD              =y
CONFIG_PARTITION             =y
CONFIG_BFLB_OTA              =y

# BSP
CONFIG_BSP_ETH_PHY           =y

# mbedtls
#CONFIG_MBEDTLS_V3 = y
CONFIG_MBEDTLS_AES_USE_HW    =n
CONFIG_MBEDTLS_BIGNUM_USE_HW =n
CONFIG_MBEDTLS_ECC_USE_HW    =n
CONFIG_MBEDTLS_SHA1_USE_HW   =n
CONFIG_MBEDTLS_SHA256_USE_HW =n
CONFIG_MBEDTLS_SHA512_USE_HW =n

# wifi
CONFIG_WIFI_IPERF =y


# Message Router
CONFIG_BSP_MR               =y
CONFIG_MR_SDIO_DRIVER       =y
CONFIG_MR_SDIO_QUEUE_DEPTH  =4

CONFIG_MR_NETDEV            =y
CONFIG_MR_TTY               =y
CONFIG_MR_VIRTUALCHAN       =y

#CONFIG_IPV6               =y
CONFIG_NETBUS             =y
CONFIG_NETHUB             =y
CONFIG_NETHUB_NETLINK     =y
CONFIG_HOSTROUTER_INF     =y
CONFIG_HOSTROUTER_CHANNEL =y

CONFIG_ATMODULE_TTY       =y
CONFIG_ATMODULE_WORK_Q    =y
CONFIG_ATMODULE_OTA       =y
CONFIG_ATMODULE_NANO      =y
CONFIG_ATMODULE_WIFI_STA  =y
CONFIG_ATMODULE_WIFI_AP   =y
CONFIG_ATMODULE_NETHUB_WIFICHANNELAUTO =y

ifeq ($(CHIP),bl618dg)
    CONFIG_ROMAPI             =n
    # enable hotplug
    CONFIG_SDIO3_SOFT_RST_INT_USER =y
    CONFIG_DUALCORE_DISABLE   =y
    CONFIG_WRAM_FOR_AP_SIZE   = 0x50000
    CONFIG_RAM_FOR_AP_SIZE    = 0x50000
endif

