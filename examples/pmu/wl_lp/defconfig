CONFIG_NEWLIB               =n
CONFIG_NEWLIB_STANDARD      =n

# Components
CONFIG_BFLB_LOG =n
CONFIG_FREERTOS =y
CONFIG_POSIX =y
CONFIG_TLSF =y
CONFIG_SHELL =y
CONFIG_LWIP =y
CONFIG_RF =y
CONFIG_MBEDTLS =y
# CONFIG_PSRAM =y
CONFIG_DHCPD =y
CONFIG_PING =y
# CONFIG_MQTT =y

CONFIG_VSNPRINTF_NANO       =n
CONFIG_VSNPRINTF_FLOAT      =y
CONFIG_VSNPRINTF_FLOAT_EX   =y
CONFIG_VSNPRINTF_LONG_LONG  =y

# Config
## mbedtls
CONFIG_MBEDTLS_AES_USE_HW =y
CONFIG_MBEDTLS_BIGNUM_USE_HW =y
CONFIG_MBEDTLS_ECC_USE_HW =y
CONFIG_MBEDTLS_SHA1_USE_HW =y
CONFIG_MBEDTLS_SHA256_USE_HW =y
CONFIG_MBEDTLS_SHA512_USE_HW =y

#CONFIG_LOG_DISABLE          =n
#CONFIG_ASSERT_DISABLE       =n
#CONFIG_LOG_LEVEL            =3
#CONFIG_LOG_POOL_SIZE        =1024

# lpfw
CONFIG_LPAPP =y
CONFIG_POST_BUILDS_CONCAT_WITH_LP_FW=y
CONFIG_PM =y
CONFIG_LWIP_LP =y

CONFIG_MACSW_SELECT = default

CONFIG_PWRMGMT               =y
CONFIG_TICKLESS_CUSTOMIZE    =y
CONFIG_TICKLESS_EXT          =y

# easyflash
CONFIG_LITTLEFS              =y
CONFIG_LITTLEFS_KV_EASYFLASH =y
CONFIG_BFLB_MTD              =y
CONFIG_PARTITION             =y


# WiFi stack selection: BL616 uses fhost; BL616CL/BL618DG use wl80211
CONFIG_WIFI6 =y
ifeq ($(CHIP),bl616cl)
    CONFIG_WL80211 =y
    CONFIG_BL_WPA_SUPPLICANT =y
    CONFIG_WL80211_WRAM_MEM_SIZE_LIMIT ?= 0x4000
else ifeq ($(CHIP),bl618dg)
    CONFIG_WL80211 =y
    CONFIG_BL_WPA_SUPPLICANT =y
    CONFIG_WL80211_WRAM_MEM_SIZE_LIMIT ?= 0x4000
else
    CONFIG_FHOST =y
endif

ifeq ($(CHIP),bl616)
    # DCDC ENABLE
    CONFIG_DCDC_ENABLE =n
endif

ifeq ($(CHIP),bl618dg)
    CONFIG_CLOCK_SOURCE_EF_PARAM =n
    CONFIG_ROMAPI            =n
    CONFIG_DUALCORE_DISABLE  =y
    CONFIG_WRAM_FOR_AP_SIZE   = 0x50000
    CONFIG_RAM_FOR_AP_SIZE    = 0x50000
endif

ifeq ($(CHIP),bl616cl)
    CONFIG_CLOCK_SOURCE_EF_PARAM =n
    CONFIG_BL616CL_POWER_SUPPLY_EXT_DCDC_SOC =n
    CONFIG_BL616CL_POWER_SUPPLY_EXT_DCDC_SYS =n
    CONFIG_BL616CL_DCDC_CTRL_USE_STD =n
    CONFIG_BL616CL_DCDC_CTRL_PIN =0xFF
endif

