# rom
mem 0x20f60000 0x21000000 ro
mem 0x60f60000 0x61000000 ro
mem 0xa0f60000 0xa1000000 ro

# flash
mem 0x30000000 0x38000000 ro
mem 0x70000000 0x78000000 ro
mem 0xB0000000 0xB8000000 ro

# reg
mem 0x20000000 0x20f60000 rw

# ram
mem 0x21000000 0x30000000 rw
mem 0x61000000 0x70000000 rw
mem 0xa1000000 0xb0000000 rw

# psram
mem 0x38000000 0x40000000 rw
mem 0x78000000 0x80000000 rw
mem 0xB9000000 0xC0000000 rw

# core id
mem 0xf0000000 0xf0001000 rw

# lp ram
mem 0x00010000 0x00100000 rw
mem 0x40010000 0x40100000 rw
mem 0x80010000 0x80100000 rw
